# Supabase Configuration
PUBLIC_SUPABASE_URL=your_supabase_project_url
PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Resend API Key (for sending invitation emails)
RESEND_API_KEY=your_resend_api_key

# Site URL (for generating invitation links)
PUBLIC_SITE_URL=http://localhost:5173

# Mux Video Configuration (for native video uploads)
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret
MUX_WEBHOOK_SECRET=your_mux_webhook_signing_secret

# Stripe Configuration (for payments)
# Keep BOTH test and live keys set at all times; switch with STRIPE_MODE so you
# never have to swap key values. STRIPE_MODE must be exactly "live" to go live;
# anything else (or unset) stays on test. Code resolves the _LIVE/_TEST var for
# the active mode, falling back to the legacy unsuffixed vars below if present.
STRIPE_MODE=test

STRIPE_SECRET_KEY_TEST=sk_test_...
PUBLIC_STRIPE_PUBLISHABLE_KEY_TEST=pk_test_...
STRIPE_WEBHOOK_SECRET_TEST=whsec_...

STRIPE_SECRET_KEY_LIVE=sk_live_...
PUBLIC_STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_...
STRIPE_WEBHOOK_SECRET_LIVE=whsec_...

# Legacy single-key vars (optional) — used as a fallback when the _TEST/_LIVE
# var for the active mode is not set. Prefer the mode-suffixed vars above.
# STRIPE_SECRET_KEY=sk_test_...
# PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Mock Mode (set to "true" to simulate payments without Stripe)
# Useful for local development and UI testing
STRIPE_MOCK_MODE=true